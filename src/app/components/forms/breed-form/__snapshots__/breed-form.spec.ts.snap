// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`BreedForm > should match the snapshot 1`] = `"<div ngform="addBreedForm" class="fixed top-0 left-0 w-full h-full bg-black/50 flex items-center justify-center"><form novalidate="" class="bg-surface p-6 rounded shadow-md w-96 flex flex-col gap-4 ng-untouched ng-pristine ng-valid"><div class="text-xl font-bold">Add New Breed to Favorites</div><div><legend class="mb-1 font-medium text-slate-800">Breed Name</legend><input formcontrolname="breedName" type="text" placeholder="Breed Name" class="border border-slate-400 p-2 rounded w-full ng-untouched ng-pristine ng-valid"></div><div><legend class="mb-1 font-medium text-slate-800">Breed Age</legend><app-choose-quantity formcontrolname="breedAge" class="ng-untouched ng-pristine ng-valid"><div class="flex items-center"><button type="button" class="bg-slate-300 text-slate-800 px-3 py-1 rounded-l disabled:opacity-50"> - </button><div><span class="w-16 text-center block">0</span></div><button type="button" class="bg-slate-300 text-slate-800 px-3 py-1 rounded-r disabled:opacity-50"> + </button></div></app-choose-quantity></div><div><legend class="mb-1 font-medium text-slate-800">Breed Weight</legend><app-choose-quantity formcontrolname="breedWeight" class="ng-untouched ng-pristine ng-valid"><div class="flex items-center"><button type="button" class="bg-slate-300 text-slate-800 px-3 py-1 rounded-l disabled:opacity-50"> - </button><div><span class="w-16 text-center block">0</span></div><button type="button" class="bg-slate-300 text-slate-800 px-3 py-1 rounded-r disabled:opacity-50"> + </button></div></app-choose-quantity></div><div><legend class="mb-1 font-medium text-slate-800">Breed Height</legend><app-choose-quantity formcontrolname="breedHeight" class="ng-untouched ng-pristine ng-valid"><div class="flex items-center"><button type="button" class="bg-slate-300 text-slate-800 px-3 py-1 rounded-l disabled:opacity-50"> - </button><div><span class="w-16 text-center block">0</span></div><button type="button" class="bg-slate-300 text-slate-800 px-3 py-1 rounded-r disabled:opacity-50"> + </button></div></app-choose-quantity></div><div><legend class="mb-1 font-medium text-slate-800">Breed Group</legend><input formcontrolname="breedGroup" type="text" placeholder="Breed Group" class="border p-2 rounded w-full ng-untouched ng-pristine ng-valid"></div><div><legend class="mb-1 font-medium text-slate-800">Breed Temperament</legend><input formcontrolname="breedTemperament" type="text" placeholder="Breed Temperament" class="border p-2 rounded w-full ng-untouched ng-pristine ng-valid"></div><div><legend class="mb-1 font-medium text-slate-800">Breed Life Span</legend><input formcontrolname="breedLifeSpan" type="text" placeholder="Breed Life Span" class="border p-2 rounded w-full ng-untouched ng-pristine ng-valid"></div><div><legend class="mb-1 font-medium text-slate-800">Breed Image URL</legend><input formcontrolname="breedImageUrl" type="text" placeholder="Breed Image URL" class="border p-2 rounded w-full ng-untouched ng-pristine ng-valid"></div><div class="w-full flex items-center justify-between"><button type="button" class="cancel w-full bg-gray-500 text-white p-2 rounded hover:bg-gray-600 transition mr-2"> Cancel </button><button type="submit" class="submit w-full bg-primary text-white p-2 rounded hover:bg-blue-600 transition"> Add Breed </button></div></form></div><!--container-->"`;
